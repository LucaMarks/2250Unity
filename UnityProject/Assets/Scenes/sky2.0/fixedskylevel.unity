      propertyPath: 'dialogueStages.Array.data[1].lockedLines.Array.data[1]'
      value: Have you got the propellor yet?
      objectReference: {fileID: 0}
    - target: {fileID: 862432905181989318, guid: d021415f26a98114b8e25653e970283b, type: 3}
